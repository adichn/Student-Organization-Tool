# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/

# ─── Environment / secrets ───────────────────────────────────────────────────
# Never commit real credentials.
# Commit *.example files that document required variables instead.
.env
.env.*
!.env.example
!.env.*.example

# ─── Build output ────────────────────────────────────────────────────────────
dist/
build/
.vite/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── OS artifacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Misc ────────────────────────────────────────────────────────────────────
*.local
coverage/
.nyc_output/
