PORT=5000
MONGO_URI=mongodb://localhost:27017/semester-organizer
NODE_ENV=development

# Must be a long random string — used to sign and verify JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ── AI keys ───────────────────────────────────────────────────────────────────
# DEFAULT_AI_KEY — server-side fallback Anthropic key.
#   • Used only when a caller does NOT provide x-user-api-key.
#   • Subject to a strict per-user rate limit (10 requests / hour) enforced by
#     aiGatekeeper middleware to prevent credit abuse.
#   • NEVER returned in any API response or attached to req/res objects.
#   • ANTHROPIC_API_KEY is accepted as a backward-compatible alias.
DEFAULT_AI_KEY=sk-ant-...

# Gemini key for generating embeddings (text-embedding-004, 768-dim).
# Always server-side only — never sent to or readable by the frontend.
GEMINI_API_KEY=AIza...

# ── Deep Research search providers ───────────────────────────────────────────
# Only one is required.  Tavily is preferred (academic depth mode).
# Serper is the fallback.  If neither is set, the server returns labelled
# placeholder results (demo mode).
TAVILY_API_KEY=tvly-...
SERPER_API_KEY=
