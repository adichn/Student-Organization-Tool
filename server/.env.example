PORT=5000
MONGO_URI=mongodb://localhost:27017/semester-organizer
NODE_ENV=development

# Must be a long random string — used to sign and verify JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Server-side fallback key — used when the caller does not supply x-api-key.
# Never expose this value to the frontend or include it in any API response.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI key for generating query and document embeddings.
# Always server-side only — never sent to or readable by the frontend.
VOYAGE_API_KEY=pa-...
